// Prisma schema for JLR's World Cup 2026 staff prediction league
// Run `npx prisma db push` after setting DATABASE_URL to create these tables.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------- Core people & org ----------

model Department {
  id        String   @id @default(cuid())
  name      String   @unique // canonical English name, e.g. "Product & Pricing"
  nameAr    String? // Arabic display name (falls back to `name` if null)
  shortCode String   @unique // 2-4 letter badge code shown next to names, e.g. "P&P"
  colorHex  String   @default("#9B6A43")
  createdAt DateTime @default(now())

  users User[]
}

model User {
  id           String   @id @default(cuid())
  name         String

  // Kept for internal contact / future email verification.
  // Login will use idNumber + employeeCode, not email.
  email String? @unique

  // Employee ID used for login.
  employeeCode String   @unique

  // National ID / Iqama ID used for login.
  // Optional for now so existing employees do not break immediately.
  idNumber     String?  @unique

  passwordHash String
  avatarLabel  String?
  role         Role     @default(EMPLOYEE)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  totalPoints   Int      @default(0)
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  createdAt     DateTime @default(now())

  predictions      Prediction[]
  championPick     ChampionPick?
  comments         Comment[]
  userAchievements UserAchievement[]
  rewardWinners    RewardWinner[]

  @@index([totalPoints])
  @@index([idNumber])
}

enum Role {
  EMPLOYEE
  ADMIN
}

// ---------- Tournament data ----------

model Team {
  id        String  @id @default(cuid())
  nameEn    String  @unique
  nameAr    String?
  flagEmoji String?
  group     String?

  homeMatches      Match[]        @relation("HomeTeam")
  awayMatches      Match[]        @relation("AwayTeam")
  championPickedBy ChampionPick[]
}

model Match {
  id          String   @id @default(cuid())
  externalRef String?  @unique
  round       String
  group       String?
  kickoffAt   DateTime
  venue       String?

  homeTeamId String?
  awayTeamId String?
  homeTeam   Team?   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team?   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homeTeamLabel String?
  awayTeamLabel String?

  homeScore Int?
  awayScore Int?
  status    MatchStatus @default(SCHEDULED)

  resultSource ResultSource? @default(AUTO)

  lockAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  predictions Prediction[]

  @@index([kickoffAt])
  @@index([round])
}

enum ResultSource {
  AUTO
  ADMIN
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

// ---------- Predictions & scoring ----------

model Prediction {
  id      String @id @default(cuid())
  userId  String
  matchId String

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  predHomeScore Int
  predAwayScore Int

  // null until match finishes; 4 exact score, 2 correct winner, 0 wrong
  pointsAwarded Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
}

model ChampionPick {
  id     String @id @default(cuid())
  userId String @unique
  teamId String

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  lockedAt     DateTime @default(now())
  bonusAwarded Boolean  @default(false) // true once +20 has been credited
}

// ---------- Achievements / badges ----------

model Achievement {
  id             String @id @default(cuid())
  code           String @unique
  name           String
  description    String
  icon           String
  pointThreshold Int?

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String @id @default(cuid())
  userId        String
  achievementId String

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt DateTime @default(now())

  @@unique([userId, achievementId])
}

// ---------- News & announcements ----------

model Announcement {
  id        String   @id @default(cuid())
  title     String
  titleAr   String?
  body      String
  bodyAr    String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  matchId String?
  body    String

  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([createdAt])
}


model RewardWinner {
  id        String   @id @default(cuid())
  roundKey  String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roundKey])
  @@index([userId])
}
