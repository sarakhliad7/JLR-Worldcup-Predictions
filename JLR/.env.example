# Copy this file to .env and fill in the values

# Postgres database connection string (from Vercel Postgres, Neon, or Supabase - all free)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Random secret used to encrypt sessions - generate one with:
# openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-string"

# Your deployed site URL (e.g. https://jlr-worldcup.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Secret key to protect the automatic score-sync endpoint (any random string)
CRON_SECRET="change-this-too"
